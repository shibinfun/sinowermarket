<div class="max-w-4xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-extrabold text-slate-900 mb-8"><%= t('.title') %></h1>

  <% if @cart_items.any? %>
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t('.product') %></th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t('.price') %></th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t('.quantity') %></th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t('.total') %></th>
              <th class="px-6 py-4 text-right"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @cart_items.each do |item| %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4">
                  <div class="flex items-center">
                    <%= display_variant(item.sku.images.first, { resize_to_limit: [64, 64] }, class: "h-16 w-16 rounded-lg object-contain bg-slate-50 p-2 mr-4") %>
                    <span class="font-semibold text-slate-900"><%= item.sku.name %></span>
                  </div>
                </td>
                <td class="px-6 py-4 text-slate-600">
                  <%= format_price(item.sku.price_in(@currency)) %>
                </td>
                <td class="px-6 py-4">
                  <%= form_with model: item, class: "flex items-center space-x-2" do |f| %>
                    <%= f.number_field :quantity, value: item.quantity, min: 1, class: "w-16 rounded-lg border-slate-200 text-sm focus:ring-blue-500 focus:border-blue-500", onchange: "this.form.requestSubmit()" %>
                  <% end %>
                </td>
                <td class="px-6 py-4 font-bold text-blue-600">
                  <%= format_price(item.total_price(@currency)) %>
                </td>
                <td class="px-6 py-4 text-right">
                  <%= button_to cart_item_path(item), method: :delete, class: "text-red-500 hover:text-red-700 transition-colors" do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <div class="bg-slate-50 px-6 py-8 border-t border-slate-200">
        <div class="flex flex-col items-end">
          <div class="flex items-center space-x-4 mb-6">
            <span class="text-slate-500 font-medium"><%= t('.subtotal') %></span>
            <span class="text-3xl font-black text-slate-900"><%= format_price(@cart.total_price(@currency)) %></span>
          </div>
          <div class="flex gap-4">
            <%= link_to t('.continue_shopping'), skus_path, class: "px-6 py-3 rounded-xl border border-slate-300 font-bold text-slate-700 hover:bg-slate-100 transition-colors" %>
            <%= link_to t('.checkout'), new_order_path, class: "px-8 py-3 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 shadow-md hover:shadow-lg transition-all" %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-20 bg-slate-50 rounded-3xl border-2 border-dashed border-slate-200">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white shadow-sm mb-6">
        <svg class="h-10 w-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-slate-900 mb-2"><%= t('.cart_empty') %></h2>
      <p class="text-slate-500 mb-8"><%= t('.cart_empty_description') %></p>
      <%= link_to t('.start_shopping'), skus_path, class: "inline-flex items-center px-8 py-3 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 transition-all shadow-md hover:shadow-lg" %>
    </div>
  <% end %>
</div>

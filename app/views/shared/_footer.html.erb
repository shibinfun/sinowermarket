<footer class="mt-auto bg-[#273990] border-t border-white/5">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      <!-- Brand Section -->
      <div class="lg:col-span-1">
        <%= image_tag "logo.png", alt: "Sinower Market", class: "h-8 sm:h-10 mb-4" %>
        <p class="text-white text-xs font-bold tracking-widest uppercase leading-relaxed">
          RELIABLE. EFFICIENT. BUILT FOR COMMERCIAL KITCHENS
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li>
            <%= link_to "#", class: "text-slate-400 hover:text-white transition-colors duration-200 text-sm" do %>
              About Us
            <% end %>
          </li>
          <li>
            <%= link_to "#", class: "text-slate-400 hover:text-white transition-colors duration-200 text-sm" do %>
              Warranty Policy
            <% end %>
          </li>
          <li>
            <%= link_to contact_path, class: "text-slate-400 hover:text-white transition-colors duration-200 text-sm" do %>
              Contact Us
            <% end %>
          </li>
        </ul>
      </div>

      <!-- Contact Information -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact Info</h3>
        <ul class="space-y-3">
          <li class="flex items-start">
            <svg class="w-4 h-4 text-blue-400 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span class="text-slate-400 text-sm">6155 Jimmy Carter Blvd Suite A, Norcross, GA 30071</span>
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 text-blue-400 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <%= link_to "1 (470) 392-7672", "tel:+14703927672", class: "text-slate-400 hover:text-white transition-colors duration-200 text-sm" %>
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 text-blue-400 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <%= link_to "info@sinowerus.com", "mailto:info@sinowerus.com", class: "text-slate-400 hover:text-white transition-colors duration-200 text-sm" %>
          </li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Support</h3>
        <ul class="space-y-2">
          <li>
            <%= link_to "mailto:support@sinowerus.com", class: "text-slate-400 hover:text-white transition-colors duration-200 text-sm flex items-center" do %>
              <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              support@sinowerus.com
            <% end %>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright Section -->
    <div class="border-t border-white/10 pt-8">
      <p class="text-center text-slate-400 text-sm">
        &copy; 2026 <%= link_to "Sinower&trade;", root_path, class: "hover:text-white hover:underline transition-colors duration-200" %>. All Rights Reserved.
      </p>
    </div>
  </div>
</footer>

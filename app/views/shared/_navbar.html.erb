            </div>
          </div>
        <% else %>
          <%= link_to new_user_session_path, class: "flex items-center gap-2 px-5 py-2.5 text-gray-700 hover:text-[#273990] hover:bg-gray-50 rounded-xl transition-all text-sm font-bold" do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span>Sign In</span>
          <% end %>

<!-- Main Navbar - Dark Theme -->
<nav class="fixed top-0 left-0 right-0 z-30 bg-[#282d34]" data-controller="mobile-menu">
  <!-- Utility Bar -->
  <div class="border-b border-[#C7C7C7]/20">
    <div class="max-w-screen-2xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-10 text-xs">
        <div class="hidden md:flex items-center space-x-4">
          <a href="<%= help_center_path %>" class="text-[#C7C7C7] hover:text-white transition-colors">Help Center</a>
          <span class="text-[#C7C7C7]/40">|</span>
          <a href="#" class="text-[#C7C7C7] hover:text-white transition-colors">Contact</a>
        </div>
        <div class="hidden md:flex items-center space-x-4 ml-auto">
          <% if user_signed_in? %>
            <span class="text-[#C7C7C7]"><%= current_user.email %></span>
            <%= link_to "My Account", account_root_path, class: "text-[#C7C7C7] hover:text-white transition-colors" %>
            <% if current_user.admin? %>
              <a href="<%= admin_dashboard_path %>" class="text-[#C7C7C7] hover:text-white transition-colors">Admin Panel</a>
            <% end %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "text-[#C7C7C7] hover:text-white transition-colors" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Header -->
  <div class="max-w-screen-2xl mx-auto px-4 lg:px-8">
    <div class="flex items-center justify-between py-4 gap-4">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="<%= root_path %>" class="flex items-center">
          <%= image_tag "logo.png", alt: "Sinower Market", class: "h-10 md:h-12 max-w-[180px] md:max-w-[220px]" %>
        </a>
      </div>

      <!-- Search Bar -->
      <div class="flex-1 max-w-2xl hidden md:block">
        <%= form_tag skus_path, method: :get, class: "flex" do %>
          <div class="relative flex-1">
            <input type="text" 
                   name="query" 
                   value="<%= params[:query] %>"
                   placeholder="Search products..." 
                   class="w-full h-11 pl-4 pr-4 bg-white text-slate-800 placeholder-slate-400 rounded-l-md border-0 focus:outline-none focus:ring-1 focus:ring-[#d80000] text-sm">
          </div>
          <button type="submit" 
                  class="h-11 px-8 bg-[#d80000] hover:bg-[#b80000] text-white font-semibold text-sm rounded-r-md transition-colors flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Search
          </button>
        <% end %>
      </div>

      <!-- Right Actions -->
      <div class="hidden md:flex items-center space-x-3 flex-shrink-0">
        <% if user_signed_in? %>
          <div class="relative" data-controller="dropdown">
            <button type="button" 
                    data-action="click->dropdown#toggle"
                    class="flex items-center gap-2 px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded transition-colors text-sm">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <span class="text-xs"><%= current_user.email.split('@').first %></span>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div data-dropdown-target="menu" 
                 class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-slate-200 py-1 z-50">
              <%= link_to "My Account", account_root_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 font-bold" %>
              <div class="border-t border-gray-100 my-1"></div>
              <%= link_to "My Orders", account_orders_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
              <%= button_to destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50" do %>
                Sign Out
              <% end %>
            </div>
          </div>
        <% else %>
          <%= link_to new_user_session_path, class: "flex items-center gap-2 px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded transition-colors text-sm" do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span>Login</span>
          <% end %>
        <% end %>
        
        <button class="flex items-center gap-2 px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded transition-colors text-sm">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
          <span class="hidden lg:inline">Wishlist</span>
        </button>

        <%= link_to cart_path, class: "flex items-center gap-2 px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded transition-colors text-sm relative" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
          <span class="hidden lg:inline">Cart</span>
          <% if current_cart.total_items > 0 %>
            <span class="absolute top-0 right-0 -mt-1 -mr-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-600 text-[10px] font-bold text-white">
              <%= current_cart.total_items %>
            </span>
          <% end %>
        <% end %>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden flex items-center">
        <button type="button" 
                data-action="click->mobile-menu#toggle"
                class="inline-flex items-center justify-center p-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded transition-colors">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Search -->
  <div class="md:hidden px-4 pb-3">
    <%= form_tag skus_path, method: :get, class: "flex" do %>
      <input type="text" 
             name="query" 
             value="<%= params[:query] %>"
             placeholder="Search products..." 
             class="flex-1 h-10 pl-3 pr-3 bg-white text-slate-800 placeholder-slate-400 rounded-l-md border-0 focus:outline-none text-sm">
      <button type="submit" class="h-10 px-5 bg-[#d80000] text-white rounded-r-md flex items-center">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
    <% end %>
  </div>

  <!-- Mobile Menu -->
  <div data-mobile-menu-target="menu" class="hidden md:hidden bg-[#1e2227] border-t border-[#C7C7C7]/20">
    <div class="px-4 py-3 space-y-2">
      <%= link_to "Home", root_path, class: "block px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded text-sm transition-colors" %>
      <%= link_to "My Account", account_root_path, class: "block px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded text-sm transition-colors font-bold" %>
      <%= link_to "My Orders", account_orders_path, class: "block px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded text-sm transition-colors pl-6" %>
      <%= link_to "Products", "#", class: "block px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded text-sm transition-colors" %>
      <%= link_to "Help Center", help_center_path, class: "block px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded text-sm transition-colors" %>
      <%= link_to "Contact", "#", class: "block px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded text-sm transition-colors" %>
      
      <div class="border-t border-[#C7C7C7]/20 pt-2 mt-2">
        <% if user_signed_in? %>
          <div class="px-3 py-2 text-xs text-[#C7C7C7]"><%= current_user.email %></div>
          <% if current_user.admin? %>
            <%= link_to admin_dashboard_path, class: "block px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded text-sm transition-colors" do %>
              Admin Panel
            <% end %>
          <% end %>
          <%= button_to destroy_user_session_path, method: :delete, class: "block w-full text-left px-3 py-2 text-red-400 hover:bg-red-900/30 rounded text-sm transition-colors" do %>
            Sign Out
          <% end %>
        <% else %>
          <%= link_to new_user_session_path, class: "block px-3 py-2 text-[#C7C7C7] hover:text-white hover:bg-[#4B515A] rounded text-sm transition-colors" do %>
            Sign In
          <% end %>
        <% end %>
      </div>

      <!-- Mobile Category Links -->
      <div class="border-t border-[#C7C7C7]/20 pt-2 mt-2">
        <% Category.where(parent_id: nil).order(:position).limit(8).each do |category| %>
          <%= link_to category_path(category), class: "inline-block px-3 py-1.5 mr-2 mb-2 text-xs text-[#C7C7C7] hover:text-white bg-[#4B515A] hover:bg-[#5a616b] rounded transition-colors" do %>
            <%= category.name %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Category Banner -->
  <% if controller_name == "skus" %>
    <%= render "home/category_banner" %>
  <% end %>
</nav>

<!-- Main Navbar - Light Theme -->
<nav class="fixed top-0 left-0 right-0 z-30 bg-white shadow-sm border-b border-gray-100" data-controller="mobile-menu">
  <!-- Utility Bar -->
  <div class="border-b border-gray-100 bg-gray-50">
    <div class="max-w-screen-2xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-10 text-xs">
        <div class="hidden md:flex items-center space-x-4">
          <a href="<%= help_center_path %>" class="text-gray-500 hover:text-gray-900 transition-colors">Help Center</a>
          <span class="text-gray-300">|</span>
          <a href="#" class="text-gray-500 hover:text-gray-900 transition-colors">Contact</a>
        </div>
        <div class="hidden md:flex items-center space-x-4 ml-auto">
          <% if user_signed_in? %>
            <span class="text-gray-600"><%= current_user.email %></span>
            <%= link_to "My Account", account_root_path, class: "text-gray-500 hover:text-gray-900 transition-colors" %>
            <% if current_user.admin? %>
              <a href="<%= admin_dashboard_path %>" class="text-gray-500 hover:text-gray-900 transition-colors">Admin Panel</a>
            <% end %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "text-gray-500 hover:text-gray-900 transition-colors" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Header -->
  <div class="max-w-screen-2xl mx-auto px-4 lg:px-8">
    <div class="flex items-center justify-between py-5 gap-8">
      <!-- Logo -->
      <div class="flex-shrink-0 transition-transform hover:scale-105 duration-300">
        <a href="<%= root_path %>" class="flex items-center">
          <%= image_tag "logo.png", alt: "Sinower Market", class: "h-11 md:h-14 max-w-[190px] md:max-w-[240px]" %>
        </a>
      </div>

      <!-- Search Bar -->
      <div class="flex-1 max-w-2xl hidden md:block">
        <%= form_tag skus_path, method: :get, class: "flex group" do %>
          <div class="relative flex-1">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400 group-focus-within:text-[#273990] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <input type="text" 
                   name="query" 
                   value="<%= params[:query] %>"
                   placeholder="Search for parts, brands or categories..." 
                   class="w-full h-12 pl-11 pr-4 bg-gray-50 text-gray-900 placeholder-gray-400 rounded-l-xl border border-r-0 border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#273990]/20 focus:bg-white transition-all text-sm">
          </div>
          <button type="submit" 
                  class="h-12 px-8 bg-[#273990] hover:bg-[#1d2b6d] text-white font-bold text-sm rounded-r-xl shadow-lg shadow-[#273990]/20 hover:shadow-[#273990]/40 transition-all flex items-center gap-2">
            Search
          </button>
        <% end %>
      </div>

      <!-- Right Actions -->
      <div class="hidden md:flex items-center space-x-2 flex-shrink-0">
        <% if user_signed_in? %>
          <div class="relative" data-controller="dropdown">
            <button type="button" 
                    data-action="click->dropdown#toggle"
                    class="flex items-center gap-2 px-4 py-2.5 text-gray-700 hover:text-[#273990] hover:bg-gray-50 rounded-xl transition-all text-sm font-medium">
              <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center border border-gray-200">
                <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <span><%= current_user.email.split('@').first %></span>
              <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div data-dropdown-target="menu" 
                 class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-2xl border border-gray-100 py-2 z-50 animate-in fade-in zoom-in-95 duration-150">
              <div class="px-4 py-2 mb-1 border-b border-gray-50">
                <p class="text-xs text-gray-400">Signed in as</p>
                <p class="text-sm font-bold text-gray-900 truncate"><%= current_user.email %></p>
              </div>
              <%= link_to account_root_path, class: "flex items-center px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-[#273990]" do %>
                <svg class="w-4 h-4 mr-3 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                My Profile
              <% end %>
              <%= link_to account_orders_path, class: "flex items-center px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-[#273990]" do %>
                <svg class="w-4 h-4 mr-3 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                My Orders
              <% end %>
              <div class="border-t border-gray-50 my-1"></div>
              <%= button_to destroy_user_session_path, method: :delete, class: "flex w-full items-center px-4 py-2.5 text-sm text-red-600 hover:bg-red-50" do %>
                <svg class="w-4 h-4 mr-3 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Sign Out
              <% end %>
            </div>
          </div>
        <% else %>
          <%= link_to new_user_session_path, class: "flex items-center gap-2 px-5 py-2.5 text-gray-700 hover:text-[#273990] hover:bg-gray-50 rounded-xl transition-all text-sm font-bold" do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span>Sign In</span>
          <% end %>
        <% end %>
        

        <%= link_to cart_path, class: "flex items-center gap-2 px-5 py-2.5 bg-[#273990] text-white hover:bg-[#1d2b6d] rounded-xl transition-all text-sm font-bold relative shadow-lg shadow-gray-200 hover:shadow-gray-300" do %>
          <div class="relative">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
            <% if current_cart.total_items > 0 %>
              <span class="absolute -top-2.5 -right-2.5 flex h-5 w-5 items-center justify-center rounded-full bg-[#273990] text-[10px] font-bold text-white border-2 border-white">
                <%= current_cart.total_items %>
              </span>
            <% end %>
          </div>
          <span class="hidden lg:inline">Cart</span>
        <% end %>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden flex items-center">
        <button type="button" 
                data-action="click->mobile-menu#toggle"
                class="inline-flex items-center justify-center p-2 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded transition-colors">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Search -->
  <div class="md:hidden px-4 pb-3">
    <%= form_tag skus_path, method: :get, class: "flex" do %>
      <input type="text" 
             name="query" 
             value="<%= params[:query] %>"
             placeholder="Search products..." 
             class="flex-1 h-10 pl-3 pr-3 bg-gray-50 text-slate-800 placeholder-slate-400 rounded-l-md border border-r-0 border-gray-200 focus:outline-none text-sm">
      <button type="submit" class="h-10 px-5 bg-[#273990] text-white rounded-r-md flex items-center">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
    <% end %>
  </div>

  <!-- Mobile Menu -->
  <div data-mobile-menu-target="menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <div class="px-4 py-3 space-y-2">
      <%= link_to "Home", root_path, class: "block px-3 py-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded text-sm transition-colors" %>
      <%= link_to "My Account", account_root_path, class: "block px-3 py-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded text-sm transition-colors font-bold" %>
      <%= link_to "My Orders", account_orders_path, class: "block px-3 py-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded text-sm transition-colors pl-6" %>
      <%= link_to "Products", "#", class: "block px-3 py-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded text-sm transition-colors" %>
      <%= link_to "Help Center", help_center_path, class: "block px-3 py-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded text-sm transition-colors" %>
      <%= link_to "Contact", "#", class: "block px-3 py-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded text-sm transition-colors" %>
      
      <div class="border-t border-gray-100 pt-2 mt-2">
        <% if user_signed_in? %>
          <div class="px-3 py-2 text-xs text-gray-400"><%= current_user.email %></div>
          <% if current_user.admin? %>
            <%= link_to admin_dashboard_path, class: "block px-3 py-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded text-sm transition-colors" do %>
              Admin Panel
            <% end %>
          <% end %>
          <%= button_to destroy_user_session_path, method: :delete, class: "block w-full text-left px-3 py-2 text-red-600 hover:bg-red-50 rounded text-sm transition-colors" do %>
            Sign Out
          <% end %>
        <% else %>
          <%= link_to new_user_session_path, class: "block px-3 py-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded text-sm transition-colors" do %>
            Sign In
          <% end %>
        <% end %>
      </div>

      <!-- Mobile Category Links -->
      <div class="border-t border-gray-100 pt-2 mt-2">
        <% Category.where(parent_id: nil).order(:position).limit(8).each do |category| %>
          <%= link_to category_path(category), class: "inline-block px-3 py-1.5 mr-2 mb-2 text-xs text-gray-600 hover:text-blue-600 bg-gray-100 hover:bg-blue-50 rounded transition-colors" do %>
            <%= category.name %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Category Banner -->
  <% if controller_name == "skus" %>
    <%= render "home/category_banner" %>
  <% end %>
</nav>

                  <span><%= label %></span>
                <% end %>
              <% end %>
            </div>
          </div>

          <div class="relative" data-controller="dropdown">
            <button type="button" 
                    data-action="click->dropdown#toggle"
                    class="flex items-center gap-1.5 px-2.5 py-1 bg-transparent text-gray-600 rounded-full hover:bg-gray-100 transition-all group">

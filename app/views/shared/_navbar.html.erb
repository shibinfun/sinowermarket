        <%= link_to cart_path, class: "flex items-center gap-2 px-5 py-2.5 bg-[#273990] text-white hover:bg-[#1d2b6d] rounded-xl transition-all text-sm font-bold relative shadow-lg shadow-gray-200 hover:shadow-gray-300" do %>

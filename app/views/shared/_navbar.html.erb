                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="font-bold uppercase tracking-wider"><%= @currency %></span>
              <svg class="w-3 h-3 opacity-50 group-hover:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div data-dropdown-target="menu" 
                 class="hidden absolute left-0 mt-1.5 w-36 bg-white rounded-xl shadow-2xl border border-gray-100 py-1.5 z-50 animate-in fade-in zoom-in-95 duration-150">
              <% [["USD", "$ USD"], ["CAD", "$ CAD"]].each do |curr, label| %>
                <%= link_to change_currency_path(currency: curr), class: "flex items-center px-4 py-2 text-xs text-gray-700 hover:bg-gray-50 hover:text-[#273990] transition-colors #{'font-bold text-[#273990] bg-blue-50/50' if @currency == curr}" do %>
                  <span class="uppercase mr-3 w-8 text-[10px] font-bold px-1 py-0.5 rounded border border-gray-200 bg-gray-50 group-hover:border-[#273990]/30 transition-colors"><%= curr %></span>
                  <span><%= label %></span>
                <% end %>
              <% end %>
            </div>
          </div>
          <span class="text-gray-300">|</span>

<div class="mb-6 flex items-center justify-between">
  <div>
    <%= link_to admin_orders_path, class: "text-blue-600 hover:text-blue-800 text-sm flex items-center mb-2" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      Back to Orders
    <% end %>
    <h1 class="text-3xl font-bold text-gray-900">Order #<%= @order.id %></h1>
  </div>
  
  <div class="flex space-x-3">
    <% if @order.can_ship? %>
      <%= button_to "Mark as Shipped", ship_admin_order_path(@order), method: :post, class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition shadow" %>
    <% end %>
    
    <% if @order.can_complete? %>
      <%= button_to "Mark as Delivered", complete_admin_order_path(@order), method: :post, class: "bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition shadow" %>
    <% end %>
    
    <% if !@order.cancelled? && !@order.delivered? %>
      <%= button_to "Cancel Order", cancel_admin_order_path(@order), method: :post, 
          data: { confirm: "Are you sure you want to cancel this order?" },
          class: "bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition shadow" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <!-- Order Items -->
  <div class="md:col-span-2 space-y-6">
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-lg font-bold text-gray-800">Order Items</h2>
      </div>
      <div class="p-6">
        <table class="w-full text-left">
          <thead>
            <tr class="text-gray-400 text-sm uppercase tracking-wider">
              <th class="pb-4 font-medium">Product</th>
              <th class="pb-4 font-medium text-center">Price</th>
              <th class="pb-4 font-medium text-center">Qty</th>
              <th class="pb-4 font-medium text-right">Subtotal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @order.order_items.each do |item| %>
              <tr>
                <td class="py-4">
                  <div class="flex items-center">
                    <div class="ml-3">
                      <div class="text-gray-900 font-medium"><%= item.name %></div>
                      <div class="text-gray-400 text-xs">SKU ID: <%= item.sku_id %></div>
                    </div>
                  </div>
                </td>
                <td class="py-4 text-center text-gray-600">$<%= number_with_precision(item.price, precision: 2) %></td>
                <td class="py-4 text-center text-gray-600"><%= item.quantity %></td>
                <td class="py-4 text-right text-gray-900 font-bold">$<%= number_with_precision(item.price * item.quantity, precision: 2) %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="border-t border-gray-200">
              <td colspan="3" class="pt-6 text-right text-gray-500 font-medium text-lg">Total Amount:</td>
              <td class="pt-6 text-right text-blue-600 font-black text-2xl">
                $<%= number_with_precision(@order.total_price, precision: 2) %>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <!-- Order Info -->
  <div class="space-y-6">
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-lg font-bold text-gray-800">Order Summary</h2>
      </div>
      <div class="p-6 space-y-4">
        <div>
          <label class="text-gray-400 text-xs uppercase font-bold tracking-wider">Status</label>
          <div class="mt-1">
            <span class="px-2 py-1 inline-flex text-sm leading-5 font-semibold rounded-full 
              <%= case @order.status 
                  when 'pending' then 'bg-yellow-100 text-yellow-800'
                  when 'paid' then 'bg-green-100 text-green-800'
                  when 'shipped' then 'bg-blue-100 text-blue-800'
                  when 'delivered' then 'bg-gray-100 text-gray-800'
                  when 'cancelled' then 'bg-red-100 text-red-800'
                  end %>">
              <%= @order.status.capitalize %>
            </span>
          </div>
        </div>
        <div>
          <label class="text-gray-400 text-xs uppercase font-bold tracking-wider">Date Placed</label>
          <div class="mt-1 text-gray-800"><%= @order.created_at.strftime("%Y-%m-%d %H:%M:%S") %></div>
        </div>
        <div>
          <label class="text-gray-400 text-xs uppercase font-bold tracking-wider">Customer Email</label>
          <div class="mt-1 text-gray-800"><%= @order.user&.email || "Deleted User" %></div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-lg font-bold text-gray-800">Shipping Details</h2>
      </div>
      <div class="p-6 space-y-4">
        <div>
          <label class="text-gray-400 text-xs uppercase font-bold tracking-wider">Receiver Name</label>
          <div class="mt-1 text-gray-800 font-medium"><%= @order.name %></div>
        </div>
        <div>
          <label class="text-gray-400 text-xs uppercase font-bold tracking-wider">Contact Phone</label>
          <div class="mt-1 text-gray-800"><%= @order.phone %></div>
        </div>
        <div>
          <label class="text-gray-400 text-xs uppercase font-bold tracking-wider">Address</label>
          <div class="mt-1 text-gray-800 leading-relaxed">
            <p><%= @order.province %> <%= @order.city %> <%= @order.district %></p>
            <p><%= @order.detail_address %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

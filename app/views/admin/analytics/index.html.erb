<% content_for :title, "Reports - Admin" %>

<div class="space-y-8">
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-gradient-to-br from-violet-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg shadow-violet-500/30">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Sales Reports</h1>
          <p class="text-sm text-slate-500 mt-0.5">Comprehensive analytics and performance metrics</p>
        </div>
      </div>
    </div>
    <div class="mt-4 sm:mt-0">
      <select class="block w-full rounded-xl border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-700 font-medium shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none transition-colors">
        <option>Last 30 days</option>
        <option selected>This Year (2026)</option>
        <option>Last Year (2025)</option>
      </select>
    </div>
  </div>

  <!-- Key Metrics -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
    <div class="bg-white rounded-2xl border border-slate-200/80 p-6 shadow-sm hover:shadow-md transition-shadow">
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm font-medium text-slate-500">Annual Revenue</p>
        <div class="w-9 h-9 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center shadow-md shadow-blue-500/20">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      <p class="text-2xl font-bold text-slate-900">$360,600</p>
      <div class="mt-2 flex items-center text-sm text-emerald-600 font-medium">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
        </svg>
        18.2% vs last year
      </div>
    </div>
    <div class="bg-white rounded-2xl border border-slate-200/80 p-6 shadow-sm hover:shadow-md transition-shadow">
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm font-medium text-slate-500">Avg Order Value</p>
        <div class="w-9 h-9 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center shadow-md shadow-purple-500/20">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
          </svg>
        </div>
      </div>
      <p class="text-2xl font-bold text-slate-900">$127.50</p>
      <div class="mt-2 flex items-center text-sm text-emerald-600 font-medium">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
        </svg>
        8.5% vs last year
      </div>
    </div>
    <div class="bg-white rounded-2xl border border-slate-200/80 p-6 shadow-sm hover:shadow-md transition-shadow">
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm font-medium text-slate-500">Conversion Rate</p>
        <div class="w-9 h-9 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-xl flex items-center justify-center shadow-md shadow-emerald-500/20">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
          </svg>
        </div>
      </div>
      <p class="text-2xl font-bold text-slate-900">3.24%</p>
      <div class="mt-2 flex items-center text-sm text-red-600 font-medium">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
        1.2% vs last year
      </div>
    </div>
    <div class="bg-white rounded-2xl border border-slate-200/80 p-6 shadow-sm hover:shadow-md transition-shadow">
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm font-medium text-slate-500">Return Rate</p>
        <div class="w-9 h-9 bg-gradient-to-br from-orange-500 to-orange-600 rounded-xl flex items-center justify-center shadow-md shadow-orange-500/20">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
          </svg>
        </div>
      </div>
      <p class="text-2xl font-bold text-slate-900">2.8%</p>
      <div class="mt-2 flex items-center text-sm text-emerald-600 font-medium">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
        </svg>
        0.5% improvement
      </div>
    </div>
  </div>

  <!-- Sales Chart -->
  <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm p-6 lg:p-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-lg font-bold text-slate-900">Monthly Sales Trend</h2>
      <div class="flex items-center space-x-5">
        <div class="flex items-center text-sm">
          <span class="w-3 h-3 bg-blue-500 rounded-full mr-2"></span>
          <span class="text-slate-600">Sales ($)</span>
        </div>
        <div class="flex items-center text-sm">
          <span class="w-3 h-3 bg-emerald-500 rounded-full mr-2"></span>
          <span class="text-slate-600">Orders</span>
        </div>
      </div>
    </div>
    <div class="h-72 flex items-end justify-between space-x-3 px-4">
      <% @monthly_sales.each do |m| %>
        <div class="flex-1 flex flex-col items-center group">
          <div class="w-full flex items-end space-x-1.5" style="height: 240px;">
            <!-- Sales Bar -->
            <div class="flex-1 bg-blue-100 rounded-t-lg relative group/sales" style="height: <%= (m[:sales].to_f / 48500 * 240).round %>px">
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-blue-600 to-blue-500 rounded-t-lg transition-all duration-300 group-hover/sales:from-blue-700 group-hover/sales:to-blue-600" style="height: 100%"></div>
              <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-xs px-2.5 py-1 rounded-lg opacity-0 group-hover/sales:opacity-100 transition-opacity whitespace-nowrap z-10 shadow-lg font-medium">
                $<%= number_with_delimiter(m[:sales]) %>
              </div>
            </div>
            <!-- Orders Bar -->
            <div class="flex-1 bg-emerald-100 rounded-t-lg relative group/orders" style="height: <%= (m[:orders].to_f / 378 * 240).round %>px">
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-emerald-600 to-emerald-500 rounded-t-lg transition-all duration-300 group-hover/orders:from-emerald-700 group-hover/orders:to-emerald-600" style="height: 100%"></div>
              <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-xs px-2.5 py-1 rounded-lg opacity-0 group-hover/orders:opacity-100 transition-opacity whitespace-nowrap z-10 shadow-lg font-medium">
                <%= m[:orders] %> orders
              </div>
            </div>
          </div>
          <span class="mt-3 text-xs font-medium text-slate-500"><%= m[:month] %></span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Traffic Sources & Category Performance -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Traffic Sources -->
    <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm p-6 lg:p-8">
      <h2 class="text-lg font-bold text-slate-900 mb-6">Traffic Sources</h2>
      <div class="space-y-5">
        <% @traffic_sources.each do |source| %>
          <div>
            <div class="flex items-center justify-between text-sm mb-2">
              <span class="text-slate-700 font-semibold"><%= source[:source] %></span>
              <span class="text-slate-500 font-medium"><%= number_with_delimiter(source[:visitors]) %> visitors (<%= source[:percentage] %>%)</span>
            </div>
            <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
              <div class="bg-gradient-to-r from-blue-500 to-blue-600 h-3 rounded-full transition-all duration-500 shadow-sm" style="width: <%= source[:percentage] %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Category Performance -->
    <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm p-6 lg:p-8">
      <h2 class="text-lg font-bold text-slate-900 mb-6">Category Performance</h2>
      <div class="space-y-3">
        <% @top_categories.each_with_index do |cat, idx| %>
          <div class="flex items-center justify-between p-4 rounded-xl hover:bg-slate-50 transition-colors duration-150 border border-transparent hover:border-slate-100">
            <div class="flex items-center space-x-4">
              <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold shadow-sm
                <%= idx == 0 ? 'bg-gradient-to-br from-yellow-400 to-amber-500 text-white' :
                    idx == 1 ? 'bg-gradient-to-br from-slate-300 to-slate-400 text-white' :
                    idx == 2 ? 'bg-gradient-to-br from-orange-400 to-amber-600 text-white' :
                    'bg-gradient-to-br from-slate-100 to-slate-200 text-slate-500' %>">
                <%= idx + 1 %>
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-900"><%= cat[:name] %></p>
                <p class="text-xs text-slate-500 mt-0.5"><%= cat[:percentage] %>% of total revenue</p>
              </div>
            </div>
            <p class="text-sm font-bold text-slate-900">$<%= number_with_delimiter(cat[:revenue]) %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

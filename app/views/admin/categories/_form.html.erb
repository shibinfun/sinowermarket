<%= form_with(model: [:admin, category], class: "space-y-6 bg-white p-8 rounded-2xl border border-slate-200/80 shadow-sm") do |f| %>
  <% if category.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-5">
      <div class="flex items-start">
        <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center mr-3 flex-shrink-0">
          <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-red-800"><%= pluralize(category.errors.count, "error") %> prohibited this category from being saved:</h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside space-y-1">
            <% category.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="space-y-5">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <%= f.label :name, "English Name", class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <%= f.text_field :name, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "English" %>
      </div>
      <div>
        <%= f.label :name_fr, "French Name", class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <%= f.text_field :name_fr, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "French" %>
      </div>
      <div>
        <%= f.label :name_es, "Spanish Name", class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <%= f.text_field :name_es, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "Spanish" %>
      </div>
    </div>

    <div>
      <%= f.label :parent_id, "Parent Category", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.collection_select :parent_id, Category.roots.where.not(id: category.id), :id, :name, { include_blank: "None (Create as top-level category)" }, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors" %>
      <p class="mt-2 text-xs text-slate-500">Leave blank to create a top-level category. Only two levels are supported.</p>
    </div>

    <div>
      <%= f.label :image, "Category Image", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <% if category.persisted? && category.image.attached? %>
        <div class="mt-2 mb-4 inline-block">
          <div class="relative group">
            <%= image_tag category.image, class: "h-28 w-28 object-cover rounded-xl border-2 border-white shadow-md" %>
            <div class="absolute inset-0 bg-black/30 opacity-0 group-hover:opacity-100 transition-opacity rounded-xl flex items-center justify-center">
              <span class="text-xs text-white font-medium">Current Image</span>
            </div>
          </div>
        </div>
      <% end %>
      <%= f.file_field :image, class: "block w-full text-sm text-slate-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-colors" %>
    </div>

    <div>
      <%= f.label :position, "Display Order", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.number_field :position, class: "block w-full max-w-xs rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "Lower number = higher priority" %>
    </div>
  </div>

  <div class="flex items-center justify-end space-x-3 pt-6 border-t border-slate-100">
    <%= link_to "Cancel", admin_categories_path, class: "px-5 py-2.5 border border-slate-300 text-sm font-medium rounded-xl text-slate-700 bg-white hover:bg-slate-50 transition-colors" %>
    <%= f.submit "Save Category", class: "px-6 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 border border-transparent rounded-xl shadow-sm text-sm font-semibold text-white cursor-pointer transition-all duration-200" %>
  </div>
<% end %>

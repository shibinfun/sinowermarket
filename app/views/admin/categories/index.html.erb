<% content_for :title, "Categories - Admin" %>

<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-500/30">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Categories</h1>
          <p class="text-sm text-slate-500 mt-0.5">Manage product categories and subcategories</p>
        </div>
      </div>
    </div>
    <%= link_to new_admin_category_path, class: "inline-flex items-center px-4 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white text-sm font-semibold rounded-xl shadow-md shadow-blue-600/20 hover:shadow-lg hover:shadow-blue-600/30 transition-all duration-200" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      New Category
    <% end %>
  </div>

  <!-- Categories List -->
  <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm overflow-hidden">
    <% if @categories.any? %>
      <div class="divide-y divide-slate-100">
        <% @categories.each do |category| %>
          <div class="group">
            <!-- Parent Category -->
            <div class="px-6 py-5 flex items-center justify-between bg-gradient-to-r from-white to-slate-50/50 hover:from-blue-50/50 hover:to-blue-50/30 transition-all duration-200">
              <div class="flex items-center">
                <div class="relative">
                  <%= display_image(category.image, class: "h-12 w-12 rounded-xl object-cover border-2 border-white shadow-sm") %>
                  <span class="absolute -bottom-1 -right-1 w-5 h-5 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-full flex items-center justify-center text-[9px] text-white font-bold shadow-sm">1</span>
                </div>
                <div class="ml-4">
                  <p class="text-base font-bold text-slate-900"><%= category.name %></p>
                  <p class="text-xs text-slate-500 mt-0.5"><%= pluralize(category.children.count, "subcategory") %></p>
                </div>
              </div>
              <div class="flex items-center space-x-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <%= link_to new_admin_category_path(parent_id: category.id), class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-emerald-700 bg-emerald-50 hover:bg-emerald-100 rounded-lg transition-colors duration-150", title: "Add subcategory" do %>
                  <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                  </svg>
                  Sub
                <% end %>
                <%= link_to edit_admin_category_path(category), class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors duration-150" do %>
                  <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                  Edit
                <% end %>
                <%= link_to admin_category_path(category), data: { turbo_method: :delete, turbo_confirm: "确定删除吗？这会同时删除所有子分类。" }, class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-lg transition-colors duration-150" do %>
                  <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                  Delete
                <% end %>
              </div>
            </div>

            <!-- Child Categories -->
            <% if category.children.any? %>
              <div class="bg-slate-50/50 divide-y divide-slate-100">
                <% category.children.ordered.each do |child| %>
                  <div class="px-6 py-3 pl-20 flex items-center justify-between group/child hover:bg-white transition-colors duration-150">
                    <div class="flex items-center">
                      <div class="relative">
                        <%= display_image(child.image, class: "h-9 w-9 rounded-lg object-cover border border-white shadow-sm") %>
                        <span class="absolute -bottom-1 -right-1 w-4 h-4 bg-gradient-to-r from-slate-400 to-slate-500 rounded-full flex items-center justify-center text-[8px] text-white font-bold shadow-sm">2</span>
                      </div>
                      <div class="ml-3">
                        <p class="text-sm font-semibold text-slate-800"><%= child.name %></p>
                      </div>
                    </div>
                    <div class="flex items-center space-x-2 opacity-0 group-hover/child:opacity-100 transition-opacity duration-200">
                      <%= link_to edit_admin_category_path(child), class: "text-xs font-medium text-blue-600 hover:text-blue-800 hover:underline" do %>
                        Edit
                      <% end %>
                      <span class="text-slate-300">·</span>
                      <%= link_to admin_category_path(child), data: { turbo_method: :delete, turbo_confirm: "确定删除吗？" }, class: "text-xs font-medium text-red-600 hover:text-red-800 hover:underline" do %>
                        Delete
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="py-16 text-center">
        <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
          </svg>
        </div>
        <p class="text-slate-500 font-medium">No categories yet</p>
        <p class="text-sm text-slate-400 mt-1">Create your first category to get started</p>
        <%= link_to new_admin_category_path, class: "inline-flex items-center mt-4 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          New Category
        <% end %>
      </div>
    <% end %>
  </div>
</div>

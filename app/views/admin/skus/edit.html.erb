<div class="space-y-6">
  <div class="flex items-center space-x-3">
    <%= link_to admin_skus_path, class: "inline-flex items-center text-blue-600 hover:text-blue-700 text-sm font-medium" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back
    <% end %>
  </div>
  <div class="flex items-center space-x-3">
    <div class="w-10 h-10 bg-gradient-to-br from-amber-500 to-orange-600 rounded-xl flex items-center justify-center shadow-lg shadow-amber-500/30">
      <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
      </svg>
    </div>
    <div>
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Edit SKU</h1>
      <p class="text-sm text-slate-500 mt-0.5">Update details for "<%= @sku.name %>"</p>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm p-8">
    <%= render "form", sku: @sku %>
  </div>
</div>

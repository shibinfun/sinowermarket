<%= form_with(model: [:admin, sku], class: "space-y-6") do |f| %>
  <% if sku.errors.any? %>
    <div class="p-5 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
      <div class="flex items-start">
        <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center mr-3 flex-shrink-0">
          <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-red-800 mb-2"><%= pluralize(sku.errors.count, "error") %> prohibited this SKU from being saved:</h3>
          <ul class="list-disc list-inside space-y-1">
            <% sku.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div>
      <%= f.label :name, "Name (English)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.text_field :name, class: "w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "Product name" %>
    </div>
    <div>
      <%= f.label :name_fr, "Name (French)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.text_field :name_fr, class: "w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "Nom du produit" %>
    </div>
    <div>
      <%= f.label :name_es, "Name (Spanish)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.text_field :name_es, class: "w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "Nombre del producto" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div>
      <%= f.label :intro, "Intro (English)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.text_area :intro, rows: 3, class: "w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "Short introduction" %>
    </div>
    <div>
      <%= f.label :intro_fr, "Intro (French)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.text_area :intro_fr, rows: 3, class: "w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "Introduction courte" %>
    </div>
    <div>
      <%= f.label :intro_es, "Intro (Spanish)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.text_area :intro_es, rows: 3, class: "w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", placeholder: "Introducción corta" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <div class="col-span-2 md:col-span-1">
      <%= f.label :category_id, "Category (Sub-category only)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.collection_select :category_id, Category.where.not(parent_id: nil).ordered, :id, :name, { prompt: "Select a sub-category" }, { class: "w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors" } %>
    </div>

    <div class="col-span-2 md:col-span-1">
      <%= f.label :kind, "Product Role (产品角色)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.select :kind, Sku.kinds.keys.map { |k| [k.humanize, k] }, {}, { class: "w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors" } %>
    </div>

    <div class="col-span-2">
      <%= f.label :accessory_ids_string, "Related Accessories (手动添加配件 ID)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <div class="p-4 bg-slate-50 rounded-2xl border border-slate-200">
        <%= f.text_field :accessory_ids_string, 
            class: "w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors", 
            placeholder: "Enter SKU IDs separated by commas or spaces (e.g. 286, 289)" %>
        
        <% if sku.accessories.any? %>
          <div class="mt-4 flex flex-wrap gap-2">
            <% sku.accessories.each do |acc| %>
              <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 border border-blue-200">
                <span class="mr-1">ID: <%= acc.id %></span>
                <span class="opacity-75"><%= acc.name %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      <p class="mt-2 text-xs text-slate-500 italic">Enter the IDs of other SKUs to link them as accessories. Separate multiple IDs with commas or spaces.</p>
    </div>

    <div class="col-span-2 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-4 p-4 bg-slate-50 rounded-2xl border border-slate-100">
        <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-blue-500"></div>
          USD Prices (美金)
        </h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :original_price_usd, "Original (USD)", class: "block text-[10px] font-black text-slate-500 uppercase tracking-wider mb-1.5" %>
            <%= f.number_field :original_price_usd, step: 0.01, class: "w-full rounded-xl border-slate-200 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors font-bold", placeholder: "0.00" %>
          </div>
          <div>
            <%= f.label :current_price_usd, "Sale (USD)", class: "block text-[10px] font-black text-slate-500 uppercase tracking-wider mb-1.5" %>
            <%= f.number_field :current_price_usd, step: 0.01, class: "w-full rounded-xl border-slate-200 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm transition-colors font-bold text-blue-600", placeholder: "0.00" %>
          </div>
        </div>
      </div>

      <div class="space-y-4 p-4 bg-amber-50/30 rounded-2xl border border-amber-100/50">
        <h3 class="text-xs font-black text-amber-600/60 uppercase tracking-widest flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-amber-400"></div>
          CAD Prices (加币)
        </h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :original_price_cad, "Original (CAD)", class: "block text-[10px] font-black text-slate-500 uppercase tracking-wider mb-1.5" %>
            <%= f.number_field :original_price_cad, step: 0.01, class: "w-full rounded-xl border-slate-200 shadow-sm focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 text-sm transition-colors font-bold", placeholder: "0.00" %>
          </div>
          <div>
            <%= f.label :current_price_cad, "Sale (CAD)", class: "block text-[10px] font-black text-slate-500 uppercase tracking-wider mb-1.5" %>
            <%= f.number_field :current_price_cad, step: 0.01, class: "w-full rounded-xl border-slate-200 shadow-sm focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 text-sm transition-colors font-bold text-amber-700", placeholder: "0.00" %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-span-2 space-y-6">
      <div class="flex items-center gap-4 mb-2">
        <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider">Description</h3>
        <div class="flex-grow h-px bg-slate-200"></div>
      </div>
      <div class="grid grid-cols-1 gap-6">
        <div>
          <%= f.label :description, "English Description", class: "block text-xs font-bold text-slate-500 uppercase mb-2" %>
          <%= f.rich_text_area :description, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 min-h-[150px] bg-white transition-colors prose max-w-none", placeholder: "Product description..." %>
        </div>
        <div>
          <%= f.label :description_fr, "French Description", class: "block text-xs font-bold text-slate-500 uppercase mb-2" %>
          <%= f.rich_text_area :description_fr, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 min-h-[150px] bg-white transition-colors prose max-w-none", placeholder: "Description du produit..." %>
        </div>
        <div>
          <%= f.label :description_es, "Spanish Description", class: "block text-xs font-bold text-slate-500 uppercase mb-2" %>
          <%= f.rich_text_area :description_es, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 min-h-[150px] bg-white transition-colors prose max-w-none", placeholder: "Descripción del producto..." %>
        </div>
      </div>
    </div>

    <div class="col-span-2 space-y-6">
      <div class="flex items-center gap-4 mb-2">
        <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider">Technical Data</h3>
        <div class="flex-grow h-px bg-slate-200"></div>
      </div>
      <div class="grid grid-cols-1 gap-6">
        <div>
          <%= f.label :technical_data, "English Technical Data", class: "block text-xs font-bold text-slate-500 uppercase mb-2" %>
          <%= f.rich_text_area :technical_data, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 min-h-[150px] bg-white transition-colors prose max-w-none", placeholder: "Technical specifications..." %>
        </div>
        <div>
          <%= f.label :technical_data_fr, "French Technical Data", class: "block text-xs font-bold text-slate-500 uppercase mb-2" %>
          <%= f.rich_text_area :technical_data_fr, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 min-h-[150px] bg-white transition-colors prose max-w-none", placeholder: "Données techniques..." %>
        </div>
        <div>
          <%= f.label :technical_data_es, "Spanish Technical Data", class: "block text-xs font-bold text-slate-500 uppercase mb-2" %>
          <%= f.rich_text_area :technical_data_es, class: "block w-full rounded-xl border-slate-300 shadow-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 min-h-[150px] bg-white transition-colors prose max-w-none", placeholder: "Datos técnicos..." %>
        </div>
      </div>
    </div>

    <div class="col-span-2">
      <%= f.label :images, "Product Images", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.file_field :images, multiple: true, class: "w-full text-sm text-slate-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-colors" %>
      <p class="mt-2 text-xs text-slate-400">Set position numbers to order images (smaller numbers appear first).</p>
      <% if sku.persisted? && sku.images.attached? %>
        <div class="mt-4 flex flex-wrap gap-4">
          <% sku.ordered_images.each do |image| %>
            <div class="relative group border border-slate-200 rounded-xl p-2 bg-slate-50 shadow-sm" data-id="<%= image.id %>">
              <div class="w-24 h-24 mb-2">
                <%= display_variant(image, { resize_to_limit: [200, 200] }, { class: "w-full h-full object-cover rounded-lg border border-slate-200 bg-white" }) %>
              </div>
              
              <div class="flex items-center space-x-2">
                <%= number_field_tag "sku[image_positions][#{image.id}]", image.position || 0, 
                                     class: "w-16 h-8 text-xs rounded-lg border-slate-300 focus:ring-blue-500 focus:border-blue-500 text-center",
                                     title: "Sort position" %>
                
                <%= link_to delete_image_admin_sku_path(sku, image_id: image.id), 
                            data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, 
                            class: "p-1.5 bg-red-100 text-red-600 rounded-lg hover:bg-red-200 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="col-span-2">
      <%= f.label :specsheet, "Specsheet (PDF)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.file_field :specsheet, accept: "application/pdf", class: "w-full text-sm text-slate-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-colors" %>
      <% if sku.persisted? && sku.specsheet.attached? %>
        <div class="mt-3 inline-flex items-center px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl">
          <svg class="w-4 h-4 mr-2 text-red-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
          </svg>
          <%= link_to sku.specsheet.filename, url_for(sku.specsheet), target: "_blank", class: "text-sm text-blue-600 hover:underline font-medium" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex justify-end space-x-3 pt-6 border-t border-slate-100">
    <%= link_to "Cancel", admin_skus_path, class: "px-5 py-2.5 border border-slate-300 text-sm font-medium rounded-xl text-slate-700 bg-white hover:bg-slate-50 transition-colors" %>
    <%= f.submit class: "px-6 py-2.5 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 border border-transparent rounded-xl shadow-sm text-sm font-semibold text-white cursor-pointer transition-all duration-200" %>
  </div>
<% end %>

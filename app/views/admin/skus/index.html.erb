<% content_for :title, "SKUs - Admin" %>

<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-xl flex items-center justify-center shadow-lg shadow-emerald-500/30">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-slate-900 tracking-tight">SKUs</h1>
          <p class="text-sm text-slate-500 mt-0.5">Manage product stock keeping units</p>
        </div>
      </div>
    </div>
    
    <div class="flex items-center gap-3">
      <!-- Category Filter Form -->
      <%= form_tag admin_skus_path, method: :get, class: "flex items-center" do %>
        <div class="relative min-w-[200px]">
          <%= select_tag :category_id, 
              options_for_select([["All Categories", ""]] + Category.roots.order(:name).map { |c| [c.name, c.id] } + Category.where.not(parent_id: nil).order(:name).map { |c| ["- #{c.name}", c.id] }, params[:category_id]),
              onchange: "this.form.submit()",
              class: "block w-full pl-3 pr-10 py-2.5 text-sm border-slate-200 focus:outline-none focus:ring-emerald-500 focus:border-emerald-500 rounded-xl bg-slate-50/50 appearance-none cursor-pointer" %>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>
      <% end %>

      <%= link_to new_admin_sku_path, class: "inline-flex items-center px-4 py-2.5 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white text-sm font-semibold rounded-xl shadow-md shadow-emerald-600/20 hover:shadow-lg hover:shadow-emerald-600/30 transition-all duration-200" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New SKU
      <% end %>
    </div>
  </div>

  <!-- SKU Table -->
  <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm overflow-hidden">
    <% if @skus.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-gradient-to-r from-slate-50 to-slate-50/50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Product</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Category</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Price</th>
              <th class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @skus.each do |sku| %>
              <tr class="hover:bg-slate-50/70 transition-colors duration-150 group">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <%= display_variant(sku.ordered_images.first, { resize_to_limit: [48, 48] }, class: "h-12 w-12 rounded-lg object-cover border border-slate-100 shadow-sm mr-3") %>
                    <div>
                      <p class="text-sm font-semibold text-slate-900 sku-name"><%= sku.name %></p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if sku.category %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-100">
                      <%= sku.category.name %>
                    </span>
                  <% else %>
                    <span class="text-xs text-slate-400">—</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex flex-col gap-0.5">
                    <% if sku.original_price.present? %>
                      <div class="flex items-baseline gap-2">
                        <span class="text-lg font-bold text-emerald-600"><%= number_to_currency sku.current_price %></span>
                        <span class="text-xs text-slate-400 line-through decoration-slate-400/60"><%= number_to_currency sku.original_price %></span>
                      </div>
                    <% else %>
                      <span class="text-lg font-bold text-emerald-600"><%= number_to_currency sku.current_price %></span>
                    <% end %>
                    <% if sku.original_price.present? && sku.original_price > sku.current_price %>
                      <span class="text-xs font-medium text-red-500 bg-red-50 px-1.5 py-0.5 rounded w-fit">
                        Save <%= number_to_percentage((1 - sku.current_price.to_f / sku.original_price) * 100, precision: 0) %>
                      </span>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end space-x-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                    <%= link_to edit_admin_sku_path(sku), class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors duration-150" do %>
                      <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                      Edit
                    <% end %>
                    <%= button_to admin_sku_path(sku), method: :delete, data: { confirm: "Are you sure?" }, class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-lg transition-colors duration-150" do %>
                      <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                      Delete
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <!-- Pagination -->
      <% if @skus.total_pages > 1 %>
        <div class="px-6 py-4 bg-slate-50 border-t border-slate-200">
          <%= paginate @skus %>
        </div>
      <% end %>
    <% else %>
      <div class="py-16 text-center">
        <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
          </svg>
        </div>
        <p class="text-slate-500 font-medium">No SKUs yet</p>
        <p class="text-sm text-slate-400 mt-1">Create your first SKU to start managing products</p>
        <%= link_to new_admin_sku_path, class: "inline-flex items-center mt-4 px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          New SKU
        <% end %>
      </div>
    <% end %>
  </div>
</div>

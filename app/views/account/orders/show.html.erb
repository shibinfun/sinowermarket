<div class="mb-8 flex items-center justify-between">
  <div>
    <nav class="flex mb-2" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <%= link_to t('.title').split(' ').first(2).join(' '), account_orders_path, class: "inline-flex items-center text-sm font-medium text-gray-500 hover:text-blue-600 transition-colors" %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-4 h-4 text-gray-400 mx-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="ml-1 text-sm font-bold text-gray-900 md:ml-2"><%= t('account.orders.index.order_number') %><%= @order.id %></span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="text-3xl font-bold text-gray-900"><%= t('account.orders.index.order_number') %><%= @order.id %></h1>
  </div>
  <div class="flex items-center gap-3">
    <span class="px-4 py-2 rounded-xl text-sm font-bold <%= 
      case @order.status
      when 'paid' then 'bg-emerald-100 text-emerald-700'
      when 'cancelled' then 'bg-rose-100 text-rose-700'
      else 'bg-amber-100 text-amber-700'
      end %>">
      <%= @order.status.capitalize %>
    </span>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Left: Order Details & Items -->
  <div class="lg:col-span-2 space-y-8">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h2 class="text-lg font-bold text-gray-900 flex items-center">
          <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <%= t('.order_items') %>
        </h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead class="bg-gray-50/30 text-xs font-bold uppercase tracking-widest text-gray-500 border-b border-gray-100">
            <tr>
              <th class="px-6 py-4"><%= t('.product') %></th>
              <th class="px-6 py-4 text-center"><%= t('.quantity') %></th>
              <th class="px-6 py-4 text-right"><%= t('.price') %></th>
              <th class="px-6 py-4 text-right"><%= t('.subtotal') %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @order.order_items.each do |item| %>
              <tr>
                <td class="px-6 py-4">
                  <div class="flex items-center">
                    <div class="w-12 h-12 rounded-lg bg-gray-50 flex items-center justify-center mr-3 border border-gray-100">
                      <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                    <span class="text-sm font-bold text-gray-900"><%= item.name %></span>
                  </div>
                </td>
                <td class="px-6 py-4 text-center text-sm font-medium text-gray-600"><%= item.quantity %></td>
                <td class="px-6 py-4 text-right text-sm text-gray-600 font-medium"><%= format_price(item.price, @order.currency) %></td>
                <td class="px-6 py-4 text-right text-sm font-bold text-gray-900"><%= format_price(item.price * item.quantity, @order.currency) %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot class="bg-gray-50/50">
            <tr>
              <td colspan="3" class="px-6 py-4 text-right text-sm font-bold text-gray-900 uppercase tracking-wider"><%= t('.total') %></td>
              <td class="px-6 py-4 text-right text-lg font-black text-blue-600"><%= format_price(@order.total_price, @order.currency) %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <!-- Right: Sidebar Information -->
  <div class="space-y-8">
    <!-- Shipping Summary -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h2 class="text-lg font-bold text-gray-900 flex items-center">
          <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <%= t('.shipping_address') %>
        </h2>
      </div>
      <div class="p-6">
        <div class="space-y-4">
          <div>
            <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400"><%= t('.recipient_name') %></label>
            <p class="text-sm font-bold text-gray-900 mt-1"><%= @order.name %></p>
          </div>
          <div>
            <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400"><%= t('.phone_number') %></label>
            <p class="text-sm font-bold text-gray-900 mt-1"><%= @order.phone %></p>
          </div>
          <div>
            <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400"><%= t('.delivery_address') %></label>
            <p class="text-sm font-medium text-gray-700 mt-1 leading-relaxed"><%= @order.address %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Order Timeline / Info -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h2 class="text-lg font-bold text-gray-900 flex items-center">
          <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= t('.payment_information') %>
        </h2>
      </div>
      <div class="p-6">
        <div class="space-y-4">
          <div>
            <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400"><%= t('.ordered_at') %></label>
            <p class="text-sm font-medium text-gray-900 mt-1"><%= l(@order.created_at, format: :long) rescue @order.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
          </div>
          
          <% if @order.status == 'pending' %>
            <div class="pt-4 border-t border-gray-100 space-y-3">
              <p class="text-xs text-amber-600 font-medium mb-1"><%= t('.awaiting_payment') %></p>
              <%= button_to pay_order_path(@order), method: :post, class: "w-full py-3 bg-emerald-600 text-white font-bold rounded-xl hover:bg-emerald-700 transition-all shadow-lg shadow-emerald-500/20 active:scale-95 flex items-center justify-center gap-2" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                <%= t('.pay_now') %>
              <% end %>
              <%= button_to t('.cancel_order'), cancel_order_path(@order), method: :post, data: { confirm: t('.cancel_confirm') }, class: "w-full py-2.5 bg-gray-50 text-gray-500 font-bold rounded-xl hover:bg-rose-50 hover:text-rose-600 transition-all border border-gray-200 hover:border-rose-200 flex items-center justify-center gap-2 text-sm" %>
            </div>
          <% elsif @order.status == 'cancelled' %>
            <div class="pt-4 border-t border-gray-100">
              <div class="flex items-center text-rose-600 gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="text-sm font-bold"><%= t('.order_cancelled') %></span>
              </div>
              <p class="text-xs text-gray-500 mt-1"><%= t('.order_cancelled_description') %></p>
            </div>
          <% else %>
            <div class="pt-4 border-t border-gray-100">
              <div class="flex items-center text-emerald-600 gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="text-sm font-bold"><%= t('.payment_completed') %></span>
              </div>
              <p class="text-xs text-gray-500 mt-1"><%= t('.transaction_processed') %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

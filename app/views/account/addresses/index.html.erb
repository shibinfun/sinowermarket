<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-gray-900">My Addresses</h1>
  <% if @addresses.count < 3 %>
    <%= link_to new_account_address_path, class: "inline-flex items-center px-4 py-2.5 bg-blue-600 text-white text-sm font-bold rounded-xl hover:bg-blue-700 transition-all shadow-md shadow-blue-500/20" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Add New Address
    <% end %>
  <% else %>
    <div class="text-sm font-medium text-gray-500 bg-gray-100 px-4 py-2 rounded-lg">
      Maximum of 3 addresses reached
    </div>
  <% end %>
</div>

<% if @addresses.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% @addresses.each do |address| %>
      <div class="bg-white rounded-2xl shadow-sm border <%= address.is_default? ? 'border-blue-500 ring-1 ring-blue-500' : 'border-gray-200' %> p-6 relative group transition-all hover:shadow-md">
        <% if address.is_default? %>
          <div class="absolute top-0 right-0 mt-4 mr-4">
            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-blue-100 text-blue-700">
              Default
            </span>
          </div>
        <% end %>

        <div class="flex items-start mb-4">
          <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center mr-4 shrink-0">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-base font-bold text-gray-900 mb-1"><%= address.name %></h3>
            <p class="text-sm font-medium text-gray-500"><%= address.phone %></p>
          </div>
        </div>

        <div class="space-y-1 mb-6">
          <p class="text-sm text-gray-600 font-medium">
            <%= address.province %> <%= address.city %> <%= address.district %>
          </p>
          <p class="text-sm text-gray-700 leading-relaxed">
            <%= address.detail_address %>
          </p>
        </div>

        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
          <div class="flex items-center space-x-4">
            <%= link_to edit_account_address_path(address), class: "text-sm font-bold text-gray-400 hover:text-blue-600 transition-colors" do %>
              Edit
            <% end %>
            <%= button_to account_address_path(address), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "text-sm font-bold text-gray-400 hover:text-red-600 transition-colors" do %>
              Delete
            <% end %>
          </div>
          
          <% unless address.is_default? %>
            <%= button_to set_default_account_address_path(address), method: :post, class: "text-xs font-bold text-blue-600 hover:text-blue-700 transition-colors" do %>
              Set as Default
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-12 text-center">
    <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
    </div>
    <h3 class="text-lg font-bold text-gray-900 mb-2">No addresses found</h3>
    <p class="text-gray-500 mb-8 max-w-sm mx-auto">You haven't added any shipping addresses yet. Add one to speed up your checkout process.</p>
    <% if @addresses.count < 3 %>
      <%= link_to "Add New Address", new_account_address_path, class: "inline-flex items-center px-6 py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors shadow-lg shadow-blue-500/20" %>
    <% else %>
      <p class="text-sm font-bold text-gray-500">Maximum of 3 addresses reached</p>
    <% end %>
  </div>
<% end %>

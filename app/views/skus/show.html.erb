<div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- 面包屑导航 -->
  <nav class="flex mb-8 text-sm font-medium text-slate-500" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2">
      <li>
        <%= link_to "Home", root_path, class: "hover:text-blue-600 transition-colors" %>
      </li>
      <% if @parent_category %>
        <li class="flex items-center space-x-2">
          <svg class="h-5 w-5 text-slate-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
          <span class="hover:text-blue-600 cursor-default"><%= @parent_category.name %></span>
        </li>
      <% end %>
      <li class="flex items-center space-x-2">
        <svg class="h-5 w-5 text-slate-300" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
        <%= link_to @category.name, category_path(@category), class: "hover:text-blue-600 transition-colors" %>
      </li>
      <li class="flex items-center space-x-2">
        <svg class="h-5 w-5 text-slate-300" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
        <span class="text-slate-900 font-bold"><%= @sku.name %></span>
      </li>
    </ol>
  </nav>

  <div class="lg:grid lg:grid-cols-2 lg:gap-x-12 xl:gap-x-16">
    <!-- 产品图片展示 (左侧) -->
      <div class="mb-10 lg:mb-0 flex flex-row gap-6 overflow-hidden" data-controller="sku-images" data-sku-images-current-index-value="0">
        <!-- 多图预览 (如果有多张图) -->
        <% if @sku.images.count > 1 %>
          <div class="flex flex-col gap-4 overflow-y-auto overflow-x-hidden max-h-[400px] md:max-h-[600px] scrollbar-hide w-16 md:w-24 shrink-0 pb-2 pr-1">
          <% @sku.ordered_images.each_with_index do |image, index| %>
            <button class="bg-white rounded-xl border-2 <%= index == 0 ? 'border-blue-600 shadow-blue-100' : 'border-slate-200' %> overflow-hidden p-2 w-16 h-16 md:w-24 md:h-24 shrink-0 flex items-center justify-center hover:border-blue-500 cursor-pointer transition-all shadow-sm focus:outline-none"
                    data-action="click->sku-images#switch"
                    data-sku-images-target="thumbnail"
                    data-index="<%= index %>"
                    data-full-url="<%= url_for(image) %>">
              <%= image_tag image.variant(resize_to_limit: [150, 150]), class: "max-h-full max-w-full object-contain mix-blend-multiply" %>
            </button>
          <% end %>
        </div>
      <% end %>

      <div class="flex-1 bg-white rounded-3xl border border-slate-200 overflow-hidden p-8 flex items-center justify-center aspect-square shadow-sm relative group">
        <%= display_image(@sku.ordered_images.first, 
                      class: "max-h-full max-w-full object-contain mix-blend-multiply transition-all duration-300", 
                      id: "main-product-image",
                      data: { sku_images_target: "mainImage" }) %>

        <% if @sku.images.count > 1 %>
          <!-- Left Arrow -->
          <button data-action="click->sku-images#previous" 
                  class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 border border-slate-200 flex items-center justify-center text-slate-700 hover:bg-white hover:text-blue-600 transition-all shadow-md opacity-0 group-hover:opacity-100 focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>
          
          <!-- Right Arrow -->
          <button data-action="click->sku-images#next" 
                  class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 border border-slate-200 flex items-center justify-center text-slate-700 hover:bg-white hover:text-blue-600 transition-all shadow-md opacity-0 group-hover:opacity-100 focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        <% end %>
      </div>
    </div>

    <!-- 产品信息 (右侧) -->
    <div class="flex flex-col">
      <div class="pb-8 border-b border-slate-100">
        <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-blue-50 text-blue-700 border border-blue-100 mb-4">
          SKU: <%= @sku.id %>
        </div>
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
          <%= @sku.name %>
        </h1>
        <div class="flex items-baseline gap-4 mt-6">
          <% if @sku.current_price.present? %>
            <span class="text-4xl font-black text-blue-600">
              <%= number_to_currency(@sku.current_price) %>
            </span>
            <% if @sku.original_price.present? && @sku.original_price > @sku.current_price %>
              <span class="text-xl text-slate-400 line-through">
                <%= number_to_currency(@sku.original_price) %>
              </span>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-green-100 text-green-800">
                SAVE <%= number_to_currency(@sku.original_price - @sku.current_price) %>
              </span>
            <% end %>
          <% else %>
            <span class="text-2xl font-bold text-slate-700">Contact for Pricing</span>
          <% end %>
        </div>
      </div>

      <div class="py-8 space-y-8">
        <!-- 下载 PDF -->
        <% if @sku.specsheet.attached? %>
          <div class="bg-slate-50 rounded-2xl p-6 border border-slate-200">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center text-red-600 mr-4">
                  <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900">Technical Datasheet</h4>
                  <p class="text-sm text-slate-500">PDF Specification Document</p>
                </div>
              </div>
              <%= link_to url_for(@sku.specsheet), target: "_blank", class: "inline-flex items-center px-5 py-2.5 rounded-xl bg-white border border-slate-200 text-sm font-bold text-slate-700 hover:bg-slate-50 transition-all shadow-sm" do %>
                Download PDF
                <svg class="ml-2 h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Add to Cart / Contact Buttons -->
        <div class="pt-4 flex flex-col sm:flex-row gap-4">
          <% if @sku.current_price.present? %>
            <%= button_to cart_items_path(sku_id: @sku.id), class: "flex-1 inline-flex items-center justify-center px-8 py-4 rounded-2xl bg-blue-600 text-white font-bold text-lg hover:bg-blue-700 transition-all shadow-lg hover:shadow-blue-200 active:scale-95" do %>
              Add to Cart
              <svg class="ml-2 h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            <% end %>
          <% else %>
            <button class="flex-1 inline-flex items-center justify-center px-8 py-4 rounded-2xl bg-blue-600 text-white font-bold text-lg hover:bg-blue-700 transition-all shadow-lg hover:shadow-blue-200 active:scale-95">
              Request Quote
            </button>
          <% end %>
          <div data-controller="share" 
               data-share-title-value="<%= @sku.name %>" 
               data-share-text-value="Check out this product on Sinower Market: <%= @sku.name %>"
               data-share-url-value="<%= request.original_url %>"
               class="flex-none">
            <button data-action="click->share#share" class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-600 font-bold text-sm hover:bg-slate-50 transition-all active:scale-95 shadow-sm">
              Share
              <svg class="ml-1.5 h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 详细信息: 产品描述、技术规范与您的可靠伙伴 -->
  <div class="mt-20 grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch">
    <!-- 产品描述 (第一栏) -->
    <div class="flex flex-col <%= @sku.description.blank? ? 'hidden' : '' %>">
      <div class="border-b border-slate-200 mb-6">
        <h2 class="text-xl font-bold text-slate-900 pb-3 inline-block border-b-4 border-blue-600">
          Product Description
        </h2>
      </div>
      <div class="flex-1 bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-6 md:p-8 text-slate-600 prose prose-slate max-w-none">
          <%= @sku.description %>
        </div>
      </div>
    </div>

    <!-- 技术数据 (第二栏) -->
    <div class="flex flex-col <%= @sku.technical_data.blank? ? 'hidden' : '' %>">
      <div class="border-b border-slate-200 mb-6">
        <h2 class="text-xl font-bold text-slate-900 pb-3 inline-block border-b-4 border-blue-600">
          Technical Specifications
        </h2>
      </div>
      <div class="flex-1 bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-6 md:p-8 text-slate-600 prose prose-blue max-w-none">
          <%= @sku.technical_data %>
        </div>
      </div>
    </div>

    <!-- 优势与伙伴信息 (第三栏) -->
    <div class="flex flex-col">
      <div class="border-b border-slate-200 mb-6">
        <h2 class="text-xl font-bold text-slate-900 pb-3 inline-block border-b-4 border-blue-600">
          Your Reliable Partner
        </h2>
      </div>
      <div class="flex-1 flex flex-col space-y-4">
        <!-- 评分/认证卡片 -->
        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden p-6">
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-slate-600 text-sm font-medium">Price/performance:</span>
              <span class="px-2 py-0.5 bg-green-100 text-green-800 text-xs font-bold rounded">Very good</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-slate-600 text-sm font-medium">Customer satisfaction:</span>
              <span class="px-2 py-0.5 bg-green-100 text-green-800 text-xs font-bold rounded">Very good</span>
            </div>
            <div class="pt-3 border-t border-slate-100">
              <h4 class="font-bold text-slate-900 text-sm mb-1">Sinower Market Excellence Award</h4>
              <p class="text-xs text-slate-500 leading-relaxed">
                Sinower Market was awarded top marks for price/performance and customer satisfaction.
              </p>
              <div class="mt-3 flex items-center gap-2">
                <div class="px-2 py-0.5 bg-slate-100 rounded font-black text-blue-600 text-xs tracking-tighter">SINOWER</div>
                <div class="px-2 py-0.5 bg-slate-100 rounded font-black text-blue-600 text-xs tracking-tighter">QUALITY</div>
              </div>
            </div>
          </div>
        </div>

        <!-- 您的优势 -->
        <div class="flex-1 bg-blue-600 rounded-3xl shadow-md overflow-hidden p-6 text-white">
          <h3 class="text-lg font-bold mb-4">Your Advantages</h3>
          <ul class="space-y-3">
            <li class="flex items-start">
              <svg class="h-5 w-5 text-blue-200 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-xs font-medium">35,000+ products in stock</span>
            </li>
            <li class="flex items-start">
              <svg class="h-5 w-5 text-blue-200 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-xs font-medium">Free delivery across Europe</span>
            </li>
            <li class="flex items-start">
              <svg class="h-5 w-5 text-blue-200 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-xs font-medium">Price Match Promise</span>
            </li>
            <li class="flex items-start">
              <svg class="h-5 w-5 text-blue-200 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-xs font-medium">20+ years experience</span>
            </li>
          </ul>
        </div>

        <!-- 缺失信息反馈 -->
        <div class="bg-slate-900 rounded-3xl shadow-sm overflow-hidden p-6 text-white">
          <h4 class="font-bold text-sm mb-1">Missing information?</h4>
          <%= link_to contact_path, class: "inline-flex items-center text-blue-400 text-sm font-bold hover:text-blue-300 transition-colors" do %>
            Contact us directly Here 
            <svg class="ml-1 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

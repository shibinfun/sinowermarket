<div class="max-w-screen-2xl mx-auto px-8 py-10">
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8">
    <h1 class="text-3xl font-bold text-slate-900">
      <% if @category %>
        <%= @category.name %>
      <% elsif params[:query].present? %>
        Search Results for "<%= params[:query] %>"
      <% else %>
        All Products
      <% end %>
    </h1>

    <div class="flex items-center gap-4">
      <div class="flex items-center space-x-2 text-sm text-slate-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" />
        </svg>
        <span>Sort By:</span>
      </div>
      <%= form_tag skus_path, method: :get, class: "flex items-center", data: { turbo_frame: "skus_list", turbo_action: "advance" } do %>
        <%= hidden_field_tag :query, params[:query] if params[:query].present? %>
        <%= hidden_field_tag :category_id, params[:category_id] if params[:category_id].present? %>
        <%= select_tag :sort, 
            options_for_select([
              ["Latest", ""],
              ["Price: Low to High", "price_asc"],
              ["Price: High to Low", "price_desc"]
            ], params[:sort]),
            onchange: "this.form.submit()",
            class: "block w-full pl-3 pr-10 py-2 text-sm border-slate-200 focus:outline-none focus:ring-blue-500 focus:border-blue-500 rounded-xl bg-white shadow-sm appearance-none cursor-pointer min-w-[180px]" %>
      <% end %>
    </div>
  </div>

  <% if @skus.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <% @skus.each do |sku| %>
        <%= link_to sku_path(sku), class: "group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 border border-slate-100 overflow-hidden flex flex-col h-full" do %>
          <div class="aspect-square w-full overflow-hidden bg-slate-50 relative flex items-center justify-center p-6">
            <%= display_image(sku.ordered_images.first, class: "max-h-full max-w-full object-contain group-hover:scale-110 transition-transform duration-500") %>
          </div>
          
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center space-x-2 mb-2">
              <span class="px-2 py-0.5 bg-blue-50 text-blue-600 text-[10px] font-bold uppercase tracking-wider rounded">
                <%= sku.category.name %>
              </span>
            </div>
            <h3 class="text-lg font-bold text-slate-800 group-hover:text-blue-600 transition-colors duration-200 line-clamp-2 leading-tight mb-2">
              <%= sku.name %>
            </h3>

            <!-- Price Display -->
            <div class="mt-2 flex items-baseline gap-2">
              <% if sku.current_price.present? %>
                <span class="text-2xl font-black text-blue-600">
                  <%= number_to_currency(sku.current_price) %>
                </span>
                <% if sku.original_price.present? && sku.original_price > sku.current_price %>
                  <span class="text-sm text-slate-400 line-through">
                    <%= number_to_currency(sku.original_price) %>
                  </span>
                <% end %>
              <% else %>
                <span class="text-sm font-semibold text-slate-500 italic">Contact for price</span>
              <% end %>
            </div>

            <div class="mt-auto pt-4 flex items-center justify-between border-t border-slate-50">
              <span class="text-blue-600 font-bold flex items-center text-sm">
                View Details
                <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </span>
              <%= button_to cart_items_path(sku_id: sku.id), class: "p-2 bg-blue-50 text-blue-600 rounded-lg hover:bg-blue-600 hover:text-white transition-all", title: "Add to Cart" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
    
    <!-- Pagination -->
    <% if @skus.total_pages > 1 %>
      <div class="mt-12 flex justify-center">
        <%= paginate @skus %>
      </div>
    <% end %>
  <% else %>
    <div class="py-20 text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-slate-50 text-slate-300 mb-6">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-slate-800 mb-2">No products found</h3>
      <p class="text-slate-500">We couldn't find any products matching your search criteria.</p>
      <%= link_to "Browse All Products", skus_path, class: "mt-8 inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-full text-white bg-blue-600 hover:bg-blue-700 transition-colors" %>
    </div>
  <% end %>
</div>

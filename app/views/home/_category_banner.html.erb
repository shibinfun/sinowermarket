<div data-controller="category-tabs" class="w-full bg-[#e2e2e2] max-lg:hidden"
     data-action="mouseleave->category-tabs#hideAll">
  <!-- PC端一级分类 - 参考GGM布局 -->
  <div class="px-2 lg:px-4 2xl:container 2xl:mx-auto">
    <div class="mx-auto flex w-full max-w-full relative">
      <ul class="m-0 flex flex-wrap border-r border-[#f7f7f7] p-0 list-none" role="menubar" aria-label="Main navigation menu">
        <% @categories.first(18).each do |category| %>
          <li class="w-[16.6666%] cursor-pointer hover:bg-[#F7F7F7] transition-colors duration-150"
              tabindex="0"
              role="menuitem"
              data-action="mouseover->category-tabs#toggle"
              data-id="<%= category.id %>"
              data-category-tabs-target="tab">
            <div class="relative h-[37px]">
              <%= link_to category_path(category), class: "flex min-h-full items-center overflow-hidden text-ellipsis whitespace-nowrap border-l border-[#f7f7f7] border-b px-[5px] xl:px-2.5" do %>
                <% if category.image.attached? %>
                  <%= image_tag category.image, alt: "", class: "max-h-[26px] max-w-[26px] opacity-75 brightness-0 saturate-0 transition-opacity duration-300", loading: "eager", width: 26, height: 26 %>
                <% else %>
                  <div class="max-h-[26px] max-w-[26px] flex items-center justify-center">
                    <span class="text-[10px] font-bold text-slate-400"><%= category.name.first.upcase %></span>
                  </div>
                <% end %>
                <span class="ml-2 truncate text-sm font-medium text-[#1a1a1a]"><%= category.name %></span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <!-- 移动端水平滚动条 -->
  <div class="lg:hidden overflow-x-auto whitespace-nowrap scrollbar-hide container-scroll px-4 py-3 bg-slate-50 border-b border-slate-200">
    <% @categories.each do |category| %>
      <button 
        data-action="click->category-tabs#toggle" 
        data-id="<%= category.id %>"
        data-category-tabs-target="tab"
        class="inline-block px-5 py-2 text-sm font-semibold rounded-full text-slate-600 hover:text-blue-600 hover:bg-white hover:shadow-sm transition-all focus:outline-none mr-2"
      >
        <%= category.name %>
      </button>
    <% end %>
  </div>

  <!-- 二级分类展示区域 (下拉式面板) -->
  <div class="px-2 lg:px-4 pb-4">
    <% @categories.each do |category| %>
      <div 
        data-category-tabs-target="content" 
        data-id="<%= category.id %>" 
        class="hidden bg-white border-2 border-slate-300 rounded-lg shadow-lg"
      >
        <div class="py-6 px-6 max-w-screen-2xl mx-auto">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-lg font-bold text-[#1a1a1a] flex items-center">
              <span class="w-1 h-6 bg-blue-600 rounded-full mr-3"></span>
              <%= category.name %> 
              <span class="ml-3 text-sm font-normal text-slate-400">Categories</span>
            </h2>
            <%= link_to "View All", "#", class: "text-sm text-blue-600 hover:text-blue-700 underline-offset-4 hover:underline font-medium" %>
          </div>

          <% if category.children.any? %>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
              <% category.children.ordered.each do |child| %>
                <%= link_to category_path(child), class: "group relative bg-[#f7f7f7] hover:bg-blue-600 rounded-lg p-4 transition-all duration-200 border border-transparent hover:border-blue-600 hover:shadow-md" do %>
                  <div class="aspect-square w-full overflow-hidden rounded-md bg-white mb-3 flex items-center justify-center p-4 group-hover:scale-95 transition-transform duration-200">
                    <% if child.image.attached? %>
                      <%= image_tag child.image, class: "max-h-full max-w-full object-contain" %>
                    <% else %>
                      <svg class="h-10 w-10 text-slate-200 group-hover:text-blue-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    <% end %>
                  </div>
                  <div class="text-center">
                    <span class="text-sm font-medium text-[#1a1a1a] group-hover:text-white transition-colors duration-200 truncate block">
                      <%= child.name %>
                    </span>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <div class="py-8 text-center text-slate-400 italic text-sm">
              No subcategories available
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

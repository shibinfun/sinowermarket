<div data-controller="category-tabs" class="w-full bg-white max-lg:hidden border-b border-gray-100"
     data-action="mouseleave->category-tabs#hideAll">
  <!-- PC端一级分类 - 参考GGM布局 -->
  <div class="px-2 lg:px-4 2xl:container 2xl:mx-auto">
    <div class="mx-auto flex w-full max-w-full relative">
      <ul class="m-0 flex flex-wrap border-l border-gray-50 p-0 list-none" role="menubar" aria-label="Main navigation menu">
        <% @categories.first(18).each do |category| %>
          <li class="w-[16.6666%] cursor-pointer hover:bg-gray-100 transition-colors duration-150 border-r border-b border-gray-50 last:border-r-0 group"
              tabindex="0"
              role="menuitem"
              data-action="mouseover->category-tabs#toggle click->category-tabs#lock"
              data-id="<%= category.id %>"
              data-category-tabs-target="tab">
            <div class="relative h-[44px]">
              <%= link_to category_path(category), class: "flex min-h-full items-center overflow-hidden px-3" do %>
                <%= display_image(category.image, alt: "", class: "max-h-[22px] max-w-[22px] opacity-60 grayscale brightness-50 transition-all duration-300 group-hover:grayscale-0 group-hover:opacity-100", loading: "eager", width: 22, height: 22) %>
                <span class="ml-2.5 truncate text-xs font-semibold text-gray-700 tracking-tight"><%= category.name %></span>
              <% end %>
              
              <!-- 锁定提示进度条 -->
              <div class="absolute bottom-0 left-0 w-full h-[3px] bg-transparent overflow-hidden">
                <div data-category-tabs-target="indicator" 
                     data-id="<%= category.id %>"
                     class="h-full bg-blue-600 w-0 transition-none opacity-0"></div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <!-- 移动端水平滚动条 -->
  <div class="lg:hidden overflow-x-auto whitespace-nowrap scrollbar-hide container-scroll px-4 py-3 bg-slate-50 border-b border-slate-200">
    <% @categories.each do |category| %>
      <button 
        data-action="click->category-tabs#toggle" 
        data-id="<%= category.id %>"
        data-category-tabs-target="tab"
        class="inline-block px-5 py-2 text-sm font-semibold rounded-full text-slate-600 hover:text-blue-600 hover:bg-white hover:shadow-sm transition-all focus:outline-none mr-2"
      >
        <%= category.name %>
      </button>
    <% end %>
  </div>

  <!-- 二级分类展示区域 (下拉式面板) -->
  <div class="px-2 lg:px-4 relative -mt-px z-20">
    <% @categories.each do |category| %>
      <div 
        data-category-tabs-target="content" 
        data-id="<%= category.id %>" 
        data-action="mouseenter->category-tabs#toggle"
        class="hidden bg-white border border-gray-100 rounded-b-xl shadow-2xl overflow-hidden animate-in fade-in slide-in-from-top-2 duration-200"
      >
        <div class="py-8 px-8 max-w-screen-2xl mx-auto">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-gray-900 flex items-center">
              <span class="w-1.5 h-6 bg-blue-600 rounded-full mr-3"></span>
              <%= category.name %> 
              <span class="ml-3 text-sm font-normal text-gray-400">Products & Categories</span>
            </h2>
            <%= link_to category_path(category), class: "group flex items-center text-sm text-blue-600 hover:text-blue-700 font-semibold" do %>
              View All Products
              <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            <% end %>
          </div>

          <% if category.children.any? %>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
              <% category.children.ordered.each do |child| %>
                <%= link_to category_path(child), class: "group block" do %>
                  <div class="aspect-square w-full overflow-hidden rounded-xl bg-gray-50 mb-3 flex items-center justify-center p-6 border border-transparent group-hover:border-blue-100 group-hover:bg-white group-hover:shadow-md transition-all duration-300">
                    <%= display_image(child.image, class: "max-h-full max-w-full object-contain group-hover:scale-110 transition-transform duration-300") %>
                  </div>
                  <div class="text-center px-2">
                    <span class="text-sm font-medium text-gray-700 group-hover:text-blue-600 transition-colors duration-200 truncate block">
                      <%= child.name %>
                    </span>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <div class="py-12 text-center">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-50 mb-4">
                <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
              </div>
              <p class="text-gray-400 text-sm italic">Explore our quality selection in this category</p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

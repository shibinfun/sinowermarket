<div class="px-4 sm:px-6 lg:px-8">
  <div class="text-center py-16">
    <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4"><%= t('home.index.welcome') %></h1>
    <p class="text-lg text-slate-600 max-w-2xl mx-auto">
      <%= t('home.index.description') %>
    </p>
    <div class="mt-8 flex justify-center gap-4">
      <%= link_to t('home.index.browse_products'), skus_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors duration-200" %>
      <%= link_to t('home.index.contact_us'), contact_path, class: "inline-flex items-center px-6 py-3 border border-slate-300 text-base font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 transition-colors duration-200" %>
    </div>
  </div>
</div>

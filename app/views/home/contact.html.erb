<div class="bg-white">
  <!-- Hero Section -->
  <div class="relative py-16 sm:py-24 bg-[#273990] overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-r from-[#273990] to-blue-900 opacity-90"></div>
      <div class="absolute right-0 top-0 -mt-24 opacity-10">
        <svg width="400" height="400" fill="none" viewBox="0 0 400 400">
          <defs>
            <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
            </pattern>
          </defs>
          <rect width="400" height="400" fill="url(#grid)"/>
        </svg>
      </div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Partner with SINOWER USA
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-xl text-blue-100">
        Contact our team for product inquiries, technical support, or business partnerships. We are ready to help.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Contact Form -->
      <div class="lg:col-span-2 bg-gray-50 rounded-2xl p-8 shadow-sm border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Send a Message</h2>
        
        <form action="#" method="POST" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
              <input type="text" name="name" id="name" placeholder="Enter your name" 
                     class="block w-full px-4 py-3 rounded-xl border-gray-200 focus:border-[#273990] focus:ring focus:ring-[#273990]/20 transition-all outline-none border">
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
              <input type="email" name="email" id="email" placeholder="example@email.com" 
                     class="block w-full px-4 py-3 rounded-xl border-gray-200 focus:border-[#273990] focus:ring focus:ring-[#273990]/20 transition-all outline-none border">
            </div>
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
            <input type="text" name="subject" id="subject" placeholder="Inquiry topic" 
                   class="block w-full px-4 py-3 rounded-xl border-gray-200 focus:border-[#273990] focus:ring focus:ring-[#273990]/20 transition-all outline-none border">
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message Details</label>
            <textarea id="message" name="message" rows="4" placeholder="Describe your needs or questions..." 
                      class="block w-full px-4 py-3 rounded-xl border-gray-200 focus:border-[#273990] focus:ring focus:ring-[#273990]/20 transition-all outline-none border"></textarea>
          </div>

          <div>
            <button type="submit" class="w-full md:w-auto px-8 py-4 bg-[#273990] text-white font-bold rounded-xl hover:bg-blue-800 transition-colors shadow-lg shadow-blue-900/20">
              Send Message
            </button>
          </div>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="space-y-8">
        <!-- Address -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#273990]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Our Office Address</h3>
          <p class="text-gray-600 leading-relaxed">
            6155 A Jimmy Carter Blvd Suite A<br>
            Norcross, GA 30071<br>
            USA
          </p>
        </div>

        <!-- Phone -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#273990]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Service Phone</h3>
          <p class="text-gray-600 font-medium text-lg">
            1 (470) 392-7672
          </p>
        </div>

        <!-- Email -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#273990]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Official Email</h3>
          <div class="space-y-2">
            <p class="text-[#273990] font-medium hover:underline cursor-pointer">info@sinowerus.com</p>
            <p class="text-[#273990] font-medium hover:underline cursor-pointer">support@sinowerus.com</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Admin - Sinower Market" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gradient-to-br from-slate-50 via-gray-50 to-slate-100 min-h-screen">
    <div class="min-h-screen">
      <%= render "admin/shared/navbar" %>
      <%= render "admin/shared/sidebar" %>

      <!-- Main Content -->
      <main class="lg:pl-64 pt-16 min-h-screen">
        <div class="p-4 sm:p-6 lg:p-8 max-w-7xl mx-auto">
          <!-- Flash Messages -->
          <% if notice %>
            <div data-controller="flash" class="mb-6 p-4 bg-emerald-50/80 backdrop-blur-sm border border-emerald-200/60 rounded-xl text-emerald-700 text-sm flex items-center justify-between shadow-sm" role="alert">
              <div class="flex items-center">
                <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center mr-3 flex-shrink-0">
                  <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <%= notice %>
              </div>
              <button data-action="click->flash#dismiss" class="ml-4 text-emerald-700 hover:text-emerald-900 focus:outline-none">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
          <% end %>
          <% if alert %>
            <div data-controller="flash" class="mb-6 p-4 bg-red-50/80 backdrop-blur-sm border border-red-200/60 rounded-xl text-red-700 text-sm flex items-center justify-between shadow-sm" role="alert">
              <div class="flex items-center">
                <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center mr-3 flex-shrink-0">
                  <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <%= alert %>
              </div>
              <button data-action="click->flash#dismiss" class="ml-4 text-red-700 hover:text-red-900 focus:outline-none">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
